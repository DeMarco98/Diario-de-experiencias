rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.username == username
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /experiences/{experienceId} {
        allow read: if request.auth != null
          && (request.auth.uid == userId
            || (
              resource.data.keys().hasAny(['sharedParticipantUids'])
              && resource.data.sharedParticipantUids.hasAny([request.auth.uid])
            ));
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
          && (request.auth.uid == userId
            || (
              resource.data.keys().hasAny(['sharedParticipantUids'])
              && resource.data.sharedParticipantUids.hasAny([request.auth.uid])
            ));
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /customCategories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.resource.data.toUid == userId
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.status == "pending";
      }
    }
  }
}
